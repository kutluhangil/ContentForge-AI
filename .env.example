# ── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Lemon Squeezy ─────────────────────────────────────────────────────────
LEMONSQUEEZY_API_KEY=...
LEMONSQUEEZY_WEBHOOK_SECRET=...            # Webhook imza doğrulama sırrı
LEMONSQUEEZY_STORE_ID=...                  # Store ID (numerik)

# Variant ID'leri — Lemon Squeezy > Products > Variants > ID
LEMON_STARTER_MONTHLY_VARIANT_ID=123456
LEMON_STARTER_YEARLY_VARIANT_ID=123457
LEMON_PRO_MONTHLY_VARIANT_ID=123458
LEMON_PRO_YEARLY_VARIANT_ID=123459

# ── Redis (BullMQ) ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379            # Prod: redis://redis:6379

# ── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://contentforge.app
NEXT_PUBLIC_DEFAULT_LOCALE=tr
